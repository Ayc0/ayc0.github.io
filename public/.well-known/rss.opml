    <feeder:settings>
      <feeder:setting key="prefs_filter_recently_read" value="true"/>
      <feeder:setting key="pref_body_text_scale" value="1.0"/>
      <feeder:setting key="pref_show_reading_time" value="false"/>
      <feeder:setting key="pref_added_feeder_news" value="true"/>
      <feeder:setting key="prefs_filter_saved" value="false"/>
      <feeder:setting key="pref_open_links_with" value="3"/>
      <feeder:setting key="pref_show_title_unread_count" value="true"/>
      <feeder:setting key="pref_swipe_as_read" value="DISABLED"/>
      <feeder:setting key="pref_sync_on_resume" value="true"/>
      <feeder:setting key="pref_default_open_item_with" value="0"/>
      <feeder:setting key="prefs_filter_read" value="true"/>
    </feeder:settings>
