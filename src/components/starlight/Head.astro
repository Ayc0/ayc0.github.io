---
import Default from "@astrojs/starlight/components/Head.astro";
import { ClientRouter } from "astro:transitions";

import { getImagePath } from "@components/images";

// Update the sitemap to point to our custom sitemap
Astro.locals.starlightRoute.head.forEach(({ tag, attrs }) => {
  if (
    tag === "link" &&
    attrs &&
    attrs.rel === "sitemap" &&
    attrs.href === "/sitemap-index.xml"
  ) {
    attrs.href = "/site-map-index.xml";
  }
});

let imagePath: string | undefined = await getImagePath(
  Astro.locals.starlightRoute.entry.data.image,
);
---

<ClientRouter />
<Default />

{
  imagePath ? (
    <meta
      property="og:image"
      content={Astro.url.origin + import.meta.env.BASE_URL + imagePath}
    />
  ) : null
}
{
  imagePath ? (
    <meta
      name="twitter:image"
      content={Astro.url.origin + import.meta.env.BASE_URL + imagePath}
    />
  ) : null
}

<!-- https://standard.site/ -->
{
  Astro.locals.starlightRoute.entry.data.atUri ? (
    <link
      rel="site.standard.document"
      href={Astro.locals.starlightRoute.entry.data.atUri}
    />
  ) : null
}
