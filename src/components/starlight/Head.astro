---
import Default from "@astrojs/starlight/components/Head.astro";

import { getImagePath } from "@components/images";

// Update the sitemap to point to our custom sitemap
Astro.locals.starlightRoute.head.forEach(({ tag, attrs }) => {
  if (
    tag === "link" &&
    attrs &&
    attrs.rel === "sitemap" &&
    attrs.href === "/sitemap-index.xml"
  ) {
    attrs.href = "/site-map-index.xml";
  }
});

let imagePath: string | undefined = await getImagePath(
  Astro.locals.starlightRoute.entry.data.image,
);
---

<Default />

{
  imagePath ? (
    <meta
      property="og:image"
      content={Astro.url.origin + import.meta.env.BASE_URL + imagePath}
    />
  ) : null
}
{
  imagePath ? (
    <meta
      name="twitter:image"
      content={Astro.url.origin + import.meta.env.BASE_URL + imagePath}
    />
  ) : null
}

<!-- https://standard.site/ -->
{
  Astro.locals.starlightRoute.entry.data.atUri ? (
    <link
      rel="site.standard.document"
      href={Astro.locals.starlightRoute.entry.data.atUri}
    />
  ) : null
}

<style>
  @media (prefers-reduced-motion: no-preference) {
    @view-transition {
      navigation: auto;
    }
  }

  @keyframes astroFadeIn {
    from {
      opacity: 0;
      mix-blend-mode: plus-lighter;
    }
    to {
      opacity: 1;
      mix-blend-mode: plus-lighter;
    }
  }

  @keyframes astroFadeOut {
    from {
      opacity: 1;
      mix-blend-mode: plus-lighter;
    }
    to {
      opacity: 0;
      mix-blend-mode: plus-lighter;
    }
  }
  ::view-transition-old(*) {
    animation-duration: 180ms;
    animation-timing-function: cubic-bezier(0.76, 0, 0.24, 1);
    animation-fill-mode: both;
    animation-name: astroFadeOut;
  }
  ::view-transition-new(*) {
    animation-duration: 180ms;
    animation-timing-function: cubic-bezier(0.76, 0, 0.24, 1);
    animation-fill-mode: both;
    animation-name: astroFadeIn;
  }
</style>
