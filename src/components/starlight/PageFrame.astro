---
import Default from "@astrojs/starlight/components/PageFrame.astro";
import Analytics from "@components/Analytics.astro";

Astro.locals.starlightRoute.hasSidebar = false;
---

<Default hasSidebar={false}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>

<script>
  delete document.documentElement.dataset.hasSidebar;
</script>

<style is:global>
  .main-frame {
    max-width: 80ch;
  }

  @media (min-width: 50rem) {
    .main-frame {
      margin-inline: auto;
    }
  }

  @media (max-width: 50rem) {
    .title-wrapper + * {
      order: 2; /* On mobile, put search at the end */
    }
  }
  .title-wrapper + * + * {
    display: flex; /* On mobile, keep the buttons & theme in header */
    margin-left: auto; /* and put it on the right, instead of centered */
  }

  [data-series-label],
  [data-series] {
    vertical-align: middle;
    font-size: max(var(--sl-text-code-sm), 0.5em);
    font-style: italic;

    /* TODO: more beautiful colors */
    color: var(--sl-color-white);
  }
  [data-series] {
    /* TODO: more beautiful colors */
    background-color: var(--sl-color-bg-inline-code);

    margin-block: -0.125em;
    padding: 0.125em 0.375em;
    border-radius: 0.375em;

    text-decoration: none;
  }
  [data-series]:hover {
    color: var(--sl-color-text-accent);
  }

  :root {
    /* See https://sequoia.pub/comments#styling */

    /* Text colors */
    --sequoia-fg-color: var(--sl-color-text);
    --sequoia-secondary-color: var(--sl-color-gray-3);
    --sequoia-accent-color: var(--sl-color-accent);

    /* Background */
    --sequoia-bg-color: var(--sl-color-bg);

    /* Borders */
    --sequoia-border-color: var(--sl-color-hairline);
    --sequoia-border-radius: 8px;
  }
</style>

<Analytics />
